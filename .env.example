OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# En local (hors Docker)
DB_HOST=localhost
DB_PORT=5433

# En Docker, DB_HOST et DB_PORT sont surchargés automatiquement par docker-compose.yml
DB_NAME=fintech
DB_USER=
DB_PASSWORD=

# Rôle Postgres en lecture seule utilisé par l'app en exécution (créé par
# scripts/init_db.py) — distinct du compte admin DB_USER ci-dessus, qui ne
# sert qu'à l'initialisation du schéma.
READONLY_DB_PASSWORD=

# Mot de passe requis pour accéder au dashboard. Si vide, aucune
# authentification n'est demandée (dev local uniquement).
DASHBOARD_PASSWORD=

# Optionnel — protection contre l'emballement des coûts (valeurs par
# défaut déjà sûres si non définies).
# LLM_TIMEOUT_S=30
# LLM_MAX_RETRIES=2
# MAX_QUESTIONS_PAR_MINUTE=10
# MAX_SQL_ROWS=20
# SQL_STATEMENT_TIMEOUT_MS=5000

# Optionnel — active la remontée d'erreurs vers Sentry (aucune variable
# locale de stack frame n'est envoyée, voir rag/logging_config.py).
# SENTRY_DSN=
